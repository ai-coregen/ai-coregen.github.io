---
import SectionHeading from "./ui/SectionHeading.astro";
import JaText from "./ui/JaText.astro";
import { profile } from "../data/content";
---

<section class="bg-white py-16 lg:py-24" id="profile">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={profile.eyebrow}>
      <JaText tag="span" text={profile.heading} />
    </SectionHeading>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-14 items-start">
      <!-- Photo (left 2 cols) -->
      <div class="lg:col-span-2 flex justify-center" data-animate>
        <div class="w-full max-w-[320px]">
          <!-- Photo placeholder -->
          <div class="aspect-[3/4] bg-surface border border-line flex items-center justify-center mb-5">
            <div class="text-center">
              <svg class="w-16 h-16 text-neutral-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
              <span class="font-display text-neutral-400 text-sm tracking-widest">PHOTO</span>
            </div>
          </div>
          <h3 class="text-ink font-bold text-2xl text-center">
            {profile.name}
          </h3>
          <p class="text-ink text-sm text-center">
            {profile.nameReading}
          </p>
        </div>
      </div>

      <!-- Bio (right 3 cols) -->
      <div class="lg:col-span-3" data-animate data-delay="150">
        <!-- Career -->
        <div class="mb-8">
          <h4 class="text-ink font-bold text-lg mb-4">経歴</h4>
          <ul class="space-y-4">
            {profile.career.map((item) => (
              <li class="text-ink text-[15px] sm:text-base leading-relaxed">
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Social Links -->
        <div class="flex items-center gap-4">
          <a
            href={profile.links.x}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-ink hover:opacity-60 text-sm transition-opacity py-3"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
            X (Twitter)
          </a>
          <a
            href={profile.links.salon}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-ink hover:opacity-60 text-sm transition-opacity py-3"
          >
            AIサロン
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
