---
import SectionHeading from "./ui/SectionHeading.astro";
import Button from "./ui/Button.astro";
import JaText from "./ui/JaText.astro";
import { finalCta } from "../data/content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="relative bg-gradient-cta py-20 lg:py-32 overflow-hidden" id="cta">
  <!-- Light effects -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_50%,rgba(255,255,255,0.12)_0%,transparent_50%)]"
  ></div>
  <div
    class="absolute inset-0 opacity-[0.05]"
    style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="relative max-w-[1100px] mx-auto px-6 lg:px-8 text-center">
    <SectionHeading eyebrow={finalCta.eyebrow} dark align="center" rawEyebrow>
      <JaText tag="span" text={finalCta.heading} class="" />
    </SectionHeading>

    <div
      data-animate
      data-delay="100"
    >
      <JaText tag="p" text={finalCta.subCopy} class="text-white font-bold text-lg sm:text-xl lg:text-2xl max-w-[680px] mx-auto mb-3 leading-relaxed" />
    </div>
    <div
      class="max-w-[520px] mx-auto mb-4"
      data-animate
      data-delay="130"
    >
      <div class="bg-white/[0.08] border border-white/25 px-5 py-3">
        <JaText tag="p" text={finalCta.note} class="text-white font-bold text-[15px] sm:text-sm leading-relaxed" />
      </div>
    </div>
    <div
      data-animate
      data-delay="150"
    >
      <JaText tag="p" text={finalCta.disclaimer} class="text-white/50 text-sm mb-10" />
    </div>

    <!-- 資料ダウンロードの内容 -->
    <div class="max-w-[560px] mx-auto mb-10 text-left" data-animate data-delay="200">
      <div class="bg-white/[0.06] border border-white/15 p-6 lg:p-7">
        <p class="font-display text-white text-sm font-bold tracking-[0.12em] uppercase mb-4 text-center">
          {finalCta.materialsTitle}
        </p>
        <ul class="space-y-2.5 max-w-[400px] mx-auto">
          {finalCta.materials.map((item) => (
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-white/60 shrink-0 mt-2.5"></span>
              <p class="text-white/85 text-[15px] leading-relaxed">{item}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4"
      data-animate
      data-delay="250"
    >
      <Button variant="white" href={`${base}/reserve`} class="w-full sm:w-auto">
        {finalCta.primaryCta}
      </Button>
      <Button variant="secondary-dark" href={`${base}/download`} class="w-full sm:w-auto">
        {finalCta.secondaryCta}
      </Button>
    </div>
  </div>
</section>
