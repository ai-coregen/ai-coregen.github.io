---
import { nav } from "../data/content";
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-line transition-all duration-300"
>
  <div class="max-w-[1260px] mx-auto px-6 lg:px-8 flex items-center justify-between h-16 lg:h-[72px]">
    <!-- Logo -->
    <a href="#hero" class="flex items-center group min-h-[44px] shrink-0">
      <span class="text-ink font-display font-bold text-xl lg:text-2xl tracking-[0.08em] group-hover:opacity-60 transition-opacity">
        Coregen
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-6 xl:gap-7">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-ink text-sm font-bold tracking-[0.04em] hover:opacity-50 transition-opacity"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <!-- CTA -->
      <a
        href="#cta"
        class="hidden sm:inline-flex items-center bg-ink text-white font-display font-bold text-sm tracking-[0.04em] px-5 lg:px-6 py-2.5 rounded-full hover:opacity-80 transition-opacity"
      >
        無料相談を予約
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="nav-toggle"
        class="lg:hidden flex items-center justify-center w-11 h-11 -mr-2 text-ink"
        aria-label="メニューを開く"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="hamburger"><span></span><span></span><span></span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="lg:hidden mobile-panel" data-open="false">
    <nav class="flex flex-col px-6 py-2">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="mobile-link text-ink font-bold text-[15px] tracking-[0.04em] py-4 border-b border-line"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="#cta"
        class="mobile-link mt-4 mb-2 inline-flex items-center justify-center bg-ink text-white font-display font-bold text-sm tracking-[0.04em] py-3.5 rounded-full"
      >
        無料相談を予約
      </a>
    </nav>
  </div>
</header>

<style>
  /* Hamburger icon */
  .hamburger {
    position: relative;
    display: block;
    width: 24px;
    height: 16px;
  }
  .hamburger span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: #121213;
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease, top 0.25s ease;
  }
  .hamburger span:nth-child(1) { top: 0; }
  .hamburger span:nth-child(2) { top: 7px; }
  .hamburger span:nth-child(3) { top: 14px; }

  #nav-toggle[aria-expanded="true"] .hamburger span:nth-child(1) {
    top: 7px;
    transform: rotate(45deg);
  }
  #nav-toggle[aria-expanded="true"] .hamburger span:nth-child(2) {
    opacity: 0;
  }
  #nav-toggle[aria-expanded="true"] .hamburger span:nth-child(3) {
    top: 7px;
    transform: rotate(-45deg);
  }

  /* Mobile dropdown panel */
  .mobile-panel {
    position: fixed;
    top: 4rem; /* header h-16 */
    left: 0;
    right: 0;
    background: #ffffff;
    border-bottom: 1px solid var(--color-line);
    box-shadow: 0 12px 24px rgba(18, 18, 19, 0.08);
    transform: translateY(-10px);
    opacity: 0;
    visibility: hidden;
    transition: transform 0.25s ease, opacity 0.25s ease, visibility 0.25s;
  }
  .mobile-panel[data-open="true"] {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }
  .mobile-panel .mobile-link:last-of-type { border-bottom: none; }
</style>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");

  // Scroll shadow
  if (header) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 80) {
        header.classList.add("shadow-elevated");
      } else {
        header.classList.remove("shadow-elevated");
      }
    });
  }

  // Hamburger toggle
  function setMenu(open: boolean) {
    if (!menu || !toggle) return;
    menu.setAttribute("data-open", String(open));
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "メニューを閉じる" : "メニューを開く");
  }

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      setMenu(menu.getAttribute("data-open") !== "true");
    });
    // Close on link tap
    menu.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => setMenu(false))
    );
    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setMenu(false);
    });
  }
</script>
