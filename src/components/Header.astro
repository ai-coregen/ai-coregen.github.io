---
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-[1100px] mx-auto px-6 flex items-center justify-between h-16 lg:h-[72px]">
    <!-- Logo -->
    <a href="#hero" class="flex items-center gap-2 group min-h-[44px]">
      <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shadow-card">
        <span class="text-primary-600 font-black text-sm">AI</span>
      </div>
      <span class="text-white font-bold text-sm lg:text-base tracking-wide group-hover:text-white/80 transition-colors">
        AI活用研修
      </span>
    </a>

    <!-- CTA -->
    <a
      href="#"
      class="hidden sm:inline-flex items-center bg-white text-primary-600 font-bold text-sm px-5 py-2.5 rounded-full hover:bg-neutral-100 transition-all duration-300 shadow-card"
    >
      無料相談を予約
    </a>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 80) {
        header.classList.add("bg-primary-600/95", "backdrop-blur-md", "shadow-elevated");
      } else {
        header.classList.remove("bg-primary-600/95", "backdrop-blur-md", "shadow-elevated");
      }
    });
  }
</script>
