---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-line transition-all duration-300"
>
  <div class="max-w-[1260px] mx-auto px-6 lg:px-8 flex items-center justify-between h-16 lg:h-[72px]">
    <!-- Logo -->
    <a href="#hero" class="flex items-center gap-2.5 group min-h-[44px]">
      <div class="w-8 h-8 bg-ink flex items-center justify-center">
        <span class="text-white font-display font-black text-xs">AI</span>
      </div>
      <span class="text-ink font-display font-bold text-sm lg:text-base tracking-[0.1em] group-hover:opacity-60 transition-opacity">
        AI MAXIMIZE
      </span>
    </a>

    <!-- CTA -->
    <a
      href="#cta"
      class="hidden sm:inline-flex items-center bg-ink text-white font-display font-bold text-sm tracking-[0.04em] px-6 py-2.5 rounded-full hover:opacity-80 transition-opacity"
    >
      無料相談を予約
    </a>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 80) {
        header.classList.add("shadow-elevated");
      } else {
        header.classList.remove("shadow-elevated");
      }
    });
  }
</script>
