---
import SectionHeading from "./ui/SectionHeading.astro";
import Card from "./ui/Card.astro";
import { problems } from "../data/content";

const icons = [
  // 人が足りない - users
  `<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
  </svg>`,
  // AI続かない - puzzle
  `<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.491 48.491 0 01-4.163-.3c-1.108-.128-2.03-1.05-2.03-2.164v-.447c0-.112.058-.216.13-.282a48.07 48.07 0 015.17-.48h.005c.097-.001.186-.078.186-.175v0c0-.269-.135-.518-.248-.724A2.987 2.987 0 019 3.75c0-1.036 1.007-1.875 2.25-1.875S13.5 2.714 13.5 3.75c0 .369-.128.713-.349 1.003-.113.147-.207.306-.278.48h-.005c0 .097.089.175.186.175a48.12 48.12 0 015.17.48c.072.066.13.17.13.282v.447c0 1.114-.922 2.036-2.03 2.164a48.491 48.491 0 01-4.163.3.64.64 0 01-.657-.643v0z" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 12.75c-2.472 0-4.9.184-7.274.54-1.454.218-2.476 1.483-2.476 2.917v.384c0 1.434 1.022 2.7 2.476 2.917A48.716 48.716 0 0012 19.5c2.472 0 4.9-.184 7.274-.54 1.454-.218 2.476-1.483 2.476-2.917v-.384c0-1.434-1.022-2.7-2.476-2.917A48.716 48.716 0 0012 12.75z" />
  </svg>`,
  // 効率化だけ - trending
  `<svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
  </svg>`,
];
---

<section class="bg-white py-16 lg:py-24" id="problems">
  <div class="max-w-[1100px] mx-auto px-6">
    <SectionHeading>
      {problems.heading}
    </SectionHeading>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch mb-12">
      {problems.items.map((item, i) => (
        <div data-aos="fade-up" data-aos-delay={i * 100} class="h-full">
          <Card class="h-full">
            <div class="text-primary-400 mb-4">
              <Fragment set:html={icons[i]} />
            </div>
            <span class="text-primary-500/20 font-black text-3xl md:text-5xl leading-none block mb-2">
              {item.number}
            </span>
            <h3 class="text-neutral-900 font-bold text-xl lg:text-2xl mb-3">
              {item.title}
            </h3>
            <p class="text-neutral-600 text-[0.95rem] leading-relaxed">
              {item.description}
            </p>
          </Card>
        </div>
      ))}
    </div>

    <!-- Closing -->
    <div data-aos="fade-up" data-aos-delay="300">
      <p class="text-primary-600 font-semibold text-base lg:text-lg border-l-4 border-primary-400 pl-4 max-w-[600px] mx-auto text-left">
        {problems.closing}
      </p>
    </div>
  </div>
</section>
