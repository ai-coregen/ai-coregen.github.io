---
import { footer } from "../data/content";
---

<footer class="bg-gradient-footer pt-16 pb-8" id="footer">
  <div class="max-w-[1100px] mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-8 mb-12">
      <!-- Services -->
      <div>
        <h4 class="text-white text-sm font-semibold tracking-wider uppercase mb-4">
          サービス
        </h4>
        <ul class="space-y-2.5">
          {footer.services.map((service) => (
            <li>
              <a href="#services" class="text-white/50 text-sm hover:text-white transition-colors block py-1.5">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-white text-sm font-semibold tracking-wider uppercase mb-4">
          企業情報
        </h4>
        <ul class="space-y-2.5">
          {footer.company.map((item) => (
            <li>
              <a href={item.href} class="text-white/50 text-sm hover:text-white transition-colors block py-1.5">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white text-sm font-semibold tracking-wider uppercase mb-4">
          関連リンク
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a
              href={footer.social.salon}
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/50 text-sm hover:text-white transition-colors inline-flex items-center gap-1"
            >
              オンラインサロン「アイサロ」
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- SNS -->
      <div>
        <h4 class="text-white text-sm font-semibold tracking-wider uppercase mb-4">
          SNS
        </h4>
        <a
          href={footer.social.x}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-white/50 text-sm hover:text-white transition-colors py-3"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          @Hoshino_AISales
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6">
      <p class="text-white/30 text-[13px] text-center">
        {footer.copyright}
      </p>
    </div>
  </div>
</footer>
