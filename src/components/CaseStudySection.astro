---
import SectionHeading from "./ui/SectionHeading.astro";
import JaText from "./ui/JaText.astro";
import { caseStudy } from "../data/content";
---

<section class="bg-surface py-20 lg:py-32" id="cases">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={caseStudy.eyebrow}>
      {caseStudy.heading}
    </SectionHeading>

    <!-- Lead -->
    <div class="max-w-[820px] mb-12" data-animate>
      <JaText tag="p" text={caseStudy.leadCopy} class="text-ink font-bold text-lg sm:text-xl lg:text-2xl leading-relaxed" />
    </div>

    <!-- Before / After time-saving table -->
    <div class="max-w-[940px] mx-auto mb-6" data-animate>
      <JaText tag="h3" text={caseStudy.tableHeading} class="text-ink font-bold text-lg lg:text-xl mb-5" />
      <div class="border border-line bg-white">
        <!-- Header row -->
        <div class="grid grid-cols-[1.2fr_1fr_1.3fr] bg-ink text-white tracking-tight">
          <div class="p-2.5 sm:p-4 lg:p-5 text-[11px] sm:text-base lg:text-lg font-bold text-center">業務</div>
          <div class="p-2.5 sm:p-4 lg:p-5 text-[11px] sm:text-base lg:text-lg font-bold text-center border-l border-white/15">Before</div>
          <div class="p-2.5 sm:p-4 lg:p-5 text-[11px] sm:text-base lg:text-lg font-bold text-center border-l border-white/15">After</div>
        </div>
        {caseStudy.table.map((row) => {
          const idx = row.task.indexOf("（");
          const main = idx >= 0 ? row.task.slice(0, idx) : row.task;
          const sub = idx >= 0 ? row.task.slice(idx) : "";
          return (
            <div class="grid grid-cols-[1.2fr_1fr_1.3fr] border-t border-line items-center tracking-tight">
              <div class="p-2.5 sm:p-4 lg:p-5 text-center">
                <span class="block text-ink font-bold text-xs sm:text-base lg:text-lg leading-tight">{main}</span>
                {sub && <span class="block text-mute text-[10px] sm:text-xs leading-tight mt-0.5">{sub}</span>}
              </div>
              <div class="p-2.5 sm:p-4 lg:p-5 text-neutral-400 font-display font-medium text-center text-xs sm:text-base lg:text-lg border-l border-line line-through decoration-1 whitespace-nowrap">{row.before}</div>
              <div class="p-2.5 sm:p-4 lg:p-5 flex flex-col sm:flex-row items-center sm:items-baseline justify-center gap-0.5 sm:gap-2 border-l border-line">
                <span class="text-ink font-display font-black text-sm sm:text-xl lg:text-3xl leading-none whitespace-nowrap">{row.after}</span>
                <span class="text-ink font-display font-bold text-[10px] sm:text-xs lg:text-sm tracking-wide whitespace-nowrap">{row.cut}</span>
              </div>
            </div>
          );
        })}
      </div>
      <JaText tag="p" text={caseStudy.tableNote} class="text-ink text-[15px] mt-4" />
    </div>
  </div>
</section>
