---
import Button from "./ui/Button.astro";
import JaText from "./ui/JaText.astro";
import { hero } from "../data/content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const videoSrc = `${base}/hero.mp4`;
const mobileVideoSrc = `${base}/hero-mobile.mp4`;
const posterSrc = `${base}/hero-poster.jpg`;
---

<section class="relative bg-white overflow-hidden" id="hero">
  <!-- ===== 背景動画（右寄り・薄く・コピー背後。モバイル非表示） ===== -->
  <div class="hero-video-wrap" aria-hidden="true">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={posterSrc}
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
  </div>
  <!-- 可読性のための白オーバーレイ（左=白 → 右=透明） -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- ===== モバイル用 背景動画（右寄せ・画面の約2/3・最背面） ===== -->
  <div class="hero-video-mobile lg:hidden" aria-hidden="true">
    <video class="block w-full h-auto" autoplay muted loop playsinline preload="auto" poster={posterSrc}>
      <source src={mobileVideoSrc} type="video/mp4" />
    </video>
  </div>

  <div class="relative z-10 max-w-[1260px] mx-auto px-6 lg:px-8 pt-32 pb-20 lg:pt-44 lg:pb-32">
    <div class="max-w-[920px]">
      <JaText
        tag="h1"
        text={hero.mainCatch}
        class="hero-anim hero-anim-2 text-[clamp(3rem,7vw+0.5rem,5rem)] leading-[1.25] tracking-[0.08em] font-bold text-ink mb-8"
      />

      <div class="hero-anim hero-anim-3 mb-6">
        {hero.subCatch.map((line) => (
          <JaText
            tag="p"
            text={line}
            class="text-ink text-xl sm:text-2xl lg:text-[28px] font-bold leading-snug"
          />
        ))}
      </div>

      <JaText
        tag="p"
        text={hero.subLead}
        class="hero-anim hero-anim-3 text-ink text-base lg:text-lg font-bold mb-10"
      />

      <div class="hero-anim hero-anim-4 flex flex-col sm:flex-row items-stretch sm:items-center gap-4 mb-5">
        <Button variant="primary" href={`${base}/reserve`} class="w-full sm:w-auto">
          {hero.primaryCta}
        </Button>
        <Button variant="secondary" href={`${base}/download`} class="w-full sm:w-auto">
          {hero.secondaryCta}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  /* 背景動画レイヤー（∞があった右側に薄く配置） */
  .hero-video-wrap {
    position: absolute;
    top: 50%;
    left: 54%;
    width: 760px;
    max-width: 58%;
    transform: translateY(-50%);
    z-index: 0;
    opacity: 0.7;
    pointer-events: none;
    /* 動画の白っぽい背景を地の白に溶かして矩形を消す */
    mix-blend-mode: multiply;
    /* 端を大きくぼかして矩形感を消す */
    -webkit-mask-image: radial-gradient(ellipse 66% 66% at 50% 50%, #000 32%, transparent 90%);
    mask-image: radial-gradient(ellipse 66% 66% at 50% 50%, #000 32%, transparent 90%);
  }

  .hero-video {
    display: block;
    width: 100%;
    height: auto;
  }

  /* 左（コピー側）を白く残し、右へ向かって動画を見せる */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      #ffffff 28%,
      rgba(255, 255, 255, 0.55) 55%,
      rgba(255, 255, 255, 0) 100%
    );
  }

  /* モバイル用 背景動画（右寄せ・画面の約2/3・コピー最背面）。白背景を地に溶かす */
  .hero-video-mobile {
    position: absolute;
    /* メインキャッチの高さ（pt-32=128px の下）に中心を合わせる */
    top: 215px;
    right: -2%;
    width: 74%;
    transform: translateY(-50%);
    z-index: 0;
    opacity: 0.8;
    pointer-events: none;
    mix-blend-mode: multiply;
    -webkit-mask-image: radial-gradient(ellipse 86% 86% at 56% 50%, #000 54%, transparent 94%);
    mask-image: radial-gradient(ellipse 86% 86% at 56% 50%, #000 54%, transparent 94%);
  }

  /* PC: 右寄せ薄背景動画（モバイルは非表示）/ モバイル: 上記の背景動画 */
  @media (max-width: 1023px) {
    .hero-video-wrap,
    .hero-overlay {
      display: none;
    }
  }

  /* モーション抑制設定では動画を出さない */
  @media (prefers-reduced-motion: reduce) {
    .hero-video-wrap,
    .hero-video-mobile {
      display: none;
    }
  }

  /* ===== コピーの登場アニメ ===== */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-anim {
    opacity: 0;
    animation: heroFadeUp 0.8s ease-out forwards;
  }

  .hero-anim-2 { animation-delay: 0.25s; }
  .hero-anim-3 { animation-delay: 0.45s; }
  .hero-anim-4 { animation-delay: 0.65s; }
</style>
