---
import Button from "./ui/Button.astro";
import { hero } from "../data/content";
---

<section
  class="relative bg-gradient-hero overflow-hidden"
  id="hero"
>
  <!-- Decorative light effects -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_20%_50%,rgba(255,255,255,0.15)_0%,transparent_50%)]"
  ></div>
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_80%_20%,rgba(176,122,255,0.2)_0%,transparent_40%)]"
  ></div>
  <!-- Sparkle dot pattern -->
  <div
    class="absolute inset-0 opacity-[0.06]"
    style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="relative max-w-[1100px] mx-auto px-6 pt-24 pb-16 lg:pt-40 lg:pb-32">
    <!-- Main Catch -->
    <h1
      class="text-[clamp(1.75rem,5vw+0.5rem,3.5rem)] leading-[1.3] tracking-[0.04em] font-black text-white text-center mb-6"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      {hero.mainCatch}
    </h1>

    <!-- Sub Catch -->
    <div
      class="text-center mb-6"
      data-aos="fade-up"
      data-aos-delay="250"
    >
      {hero.subCatch.map((line) => (
        <p class="text-white/80 text-base lg:text-[1.375rem] font-medium leading-relaxed">
          {line}
        </p>
      ))}
    </div>

    <!-- Lead Copy -->
    <p
      class="text-white/60 text-sm lg:text-lg text-center max-w-[800px] mx-auto mb-3 leading-relaxed"
      data-aos="fade-up"
      data-aos-delay="350"
    >
      {hero.leadCopy}
    </p>
    <p
      class="text-white/90 text-sm lg:text-base font-semibold text-center mb-10"
      data-aos="fade-up"
      data-aos-delay="350"
    >
      {hero.subLead}
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-4"
      data-aos="fade-up"
      data-aos-delay="450"
    >
      <Button variant="white" class="w-full sm:w-auto">
        {hero.primaryCta}
      </Button>
      <Button variant="secondary-dark" class="w-full sm:w-auto">
        {hero.secondaryCta}
      </Button>
    </div>

    <!-- Disclaimer -->
    <p
      class="text-white/50 text-[13px] text-center"
      data-aos="fade-up"
      data-aos-delay="500"
    >
      {hero.disclaimer}
    </p>
  </div>
</section>
