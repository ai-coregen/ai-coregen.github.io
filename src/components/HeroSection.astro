---
import Button from "./ui/Button.astro";
import JaText from "./ui/JaText.astro";
import { hero } from "../data/content";
---

<section class="relative bg-white overflow-hidden" id="hero">
  <!-- 微細なグリッド（モノクロ装飾） -->
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: radial-gradient(circle, #121213 1px, transparent 1px); background-size: 44px 44px;"
  >
  </div>
  <!-- 右上のごく薄いグレーの陰影 -->
  <div
    class="absolute -top-32 -right-40 w-[640px] h-[640px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(18,18,19,0.05) 0%, transparent 70%);"
  >
  </div>

  <div class="relative max-w-[1260px] mx-auto px-6 lg:px-8 pt-32 pb-20 lg:pt-44 lg:pb-32">
    <div class="max-w-[920px]">
      <p
        class="hero-anim hero-anim-1 font-display font-bold text-xs sm:text-sm tracking-[0.2em] text-mute mb-6"
      >
        {hero.eyebrow}
      </p>

      <JaText
        tag="h1"
        text={hero.mainCatch}
        class="hero-anim hero-anim-2 text-[clamp(2.25rem,6vw+0.5rem,4rem)] leading-[1.35] tracking-[0.06em] font-bold text-ink mb-8"
      />

      <div class="hero-anim hero-anim-3 mb-6">
        {hero.subCatch.map((line) => (
          <JaText
            tag="p"
            text={line}
            class="text-ink text-base sm:text-lg lg:text-xl font-bold leading-relaxed"
          />
        ))}
      </div>

      <JaText
        tag="p"
        text={hero.leadCopy}
        class="hero-anim hero-anim-3 text-neutral-500 text-[13px] sm:text-sm lg:text-base max-w-[760px] mb-2 leading-relaxed"
      />
      <JaText
        tag="p"
        text={hero.subLead}
        class="hero-anim hero-anim-3 text-ink text-sm lg:text-base font-bold mb-10"
      />

      <div class="hero-anim hero-anim-4 flex flex-col sm:flex-row items-stretch sm:items-center gap-4 mb-5">
        <Button variant="primary" href="#cta" class="w-full sm:w-auto">
          {hero.primaryCta}
        </Button>
        <Button variant="secondary" href="#curriculum" class="w-full sm:w-auto">
          {hero.secondaryCta}
        </Button>
      </div>

      <p class="hero-anim hero-anim-5 text-neutral-400 text-[12px] tracking-wider">
        {hero.disclaimer}
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-anim {
    opacity: 0;
    animation: heroFadeUp 0.8s ease-out forwards;
  }

  .hero-anim-1 { animation-delay: 0.1s; }
  .hero-anim-2 { animation-delay: 0.25s; }
  .hero-anim-3 { animation-delay: 0.45s; }
  .hero-anim-4 { animation-delay: 0.65s; }
  .hero-anim-5 { animation-delay: 0.85s; }
</style>
