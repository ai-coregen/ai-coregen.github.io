---
import SectionHeading from "./ui/SectionHeading.astro";
import JaText from "./ui/JaText.astro";
import { services } from "../data/content";
---

<section class="bg-white py-20 lg:py-32" id="services">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={services.eyebrow}>
      <JaText tag="span" text={services.heading} class="" />
    </SectionHeading>

    <div data-animate>
      <JaText tag="p" text={services.leadCopy} class="text-neutral-700 text-[14px] sm:text-base lg:text-lg max-w-[760px] mb-12 leading-loose" />
    </div>

    <!-- Service list -->
    <div class="max-w-[900px] border-t border-line">
      {services.items.map((item, i) => (
        <div
          class="flex flex-col sm:flex-row items-start gap-4 sm:gap-8 py-7 lg:py-8 border-b border-line transition-colors hover:bg-surface"
          data-animate
          data-delay={i * 80}
        >
          <!-- Number -->
          <span class="font-display text-neutral-200 font-black text-4xl lg:text-5xl leading-none shrink-0 sm:w-16">
            {item.number}
          </span>
          <!-- Content -->
          <div class="flex-1">
            <JaText tag="h3" text={item.name} class="text-ink font-bold text-lg lg:text-xl mb-2" />
            <JaText tag="p" text={item.description} class="text-neutral-600 text-[13px] sm:text-[0.95rem] leading-relaxed" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
