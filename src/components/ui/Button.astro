---
interface Props {
  variant?: "primary" | "secondary" | "white" | "secondary-dark";
  href?: string;
  class?: string;
}

const { variant = "primary", href = "#", class: className = "" } = Astro.props;

const baseClasses =
  "group relative inline-flex items-center justify-center font-display font-bold text-sm sm:text-base tracking-[0.02em] rounded-full transition-all duration-300 cursor-pointer text-center";

// アイコンを表示するか + アイコンの円/三角の色
const config = {
  primary: {
    classes:
      "bg-ink text-white pl-8 pr-14 sm:pl-10 sm:pr-16 py-[18px] hover:opacity-80",
    icon: true,
    circle: "rgba(255,255,255,0.18)",
    tri: "#ffffff",
  },
  white: {
    classes:
      "bg-white text-ink border border-line pl-8 pr-14 sm:pl-10 sm:pr-16 py-[18px] hover:opacity-70",
    icon: true,
    circle: "#EBEBEB",
    tri: "#121213",
  },
  secondary: {
    classes:
      "bg-white text-ink border border-ink px-8 sm:px-10 py-[18px] hover:opacity-70",
    icon: false,
    circle: "",
    tri: "",
  },
  "secondary-dark": {
    classes:
      "bg-transparent text-white border border-white/40 px-8 sm:px-10 py-[18px] hover:bg-white/10 hover:border-white/70",
    icon: false,
    circle: "",
    tri: "",
  },
};

const c = config[variant];
---

<a href={href} class:list={[baseClasses, c.classes, className]}>
  <slot />
  {
    c.icon && (
      <svg
        class="absolute right-4 sm:right-5 top-1/2 -translate-y-1/2 w-7 h-7"
        viewBox="0 0 32 32"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="16" cy="16" r="16" fill={c.circle} />
        <path d="M13.5 10.5 L21 16 L13.5 21.5 Z" fill={c.tri} />
      </svg>
    )
  }
</a>
