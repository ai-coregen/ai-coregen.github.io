---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div class="bg-white rounded-lg shadow-[0_1px_3px_rgba(79,99,247,0.06)] mb-3 overflow-hidden border border-neutral-200/60 border-l-[3px] border-l-transparent">
  <button
    data-accordion-trigger
    class="w-full flex items-center justify-between text-left px-6 lg:px-8 py-5 lg:py-6 cursor-pointer hover:bg-primary-50/50 transition-colors duration-200"
    type="button"
  >
    <span class="flex items-start gap-3 pr-4">
      <span class="text-primary-500 font-bold shrink-0">Q.</span>
      <span class="text-neutral-900 font-semibold text-[1.05rem] lg:text-[1.15rem] leading-relaxed">{question}</span>
    </span>
    <svg
      data-chevron
      class="w-5 h-5 text-neutral-400 shrink-0 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </button>
  <div
    data-accordion-content
    class="overflow-hidden transition-all duration-300 ease-in-out"
    style="max-height: 0;"
  >
    <div class="px-6 lg:px-8 pb-5 lg:pb-6 pl-10 lg:pl-[3.75rem]">
      <p class="text-neutral-700 leading-relaxed">{answer}</p>
    </div>
  </div>
</div>
