---
import JaText from "./JaText.astro";

interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div class="bg-white mb-3 overflow-hidden border border-line">
  <button
    data-accordion-trigger
    class="w-full flex items-center justify-between text-left px-6 lg:px-8 py-5 lg:py-6 cursor-pointer hover:bg-surface transition-colors duration-200"
    type="button"
  >
    <span class="flex items-start gap-3 pr-4">
      <span class="font-display text-ink font-bold shrink-0">Q.</span>
      <JaText tag="span" text={question} class="text-ink font-semibold text-sm lg:text-[1.1rem] leading-relaxed" />
    </span>
    <svg
      data-chevron
      class="w-5 h-5 text-neutral-400 shrink-0 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </button>
  <div
    data-accordion-content
    class="overflow-hidden transition-all duration-300 ease-in-out"
    style="max-height: 0;"
  >
    <div class="px-6 lg:px-8 pb-5 lg:pb-6 pl-10 lg:pl-[3.75rem]">
      <JaText tag="p" text={answer} class="text-neutral-700 leading-relaxed" />
    </div>
  </div>
</div>
