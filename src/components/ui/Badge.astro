---
interface Props {
  label: string;
  value?: string;
}

const { label, value } = Astro.props;
---

<span
  class="inline-flex items-center gap-2 bg-primary-700/80 border border-primary-300/40 text-white text-sm font-semibold tracking-wider px-5 py-2.5 rounded-full backdrop-blur-sm"
>
  <svg
    class="w-4 h-4 text-accent-400 shrink-0"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
  </svg>
  {label}{value ? `：${value}` : ""}
</span>
