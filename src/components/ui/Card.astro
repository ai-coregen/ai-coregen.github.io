---
interface Props {
  variant?: "light" | "dark";
  class?: string;
}

const { variant = "light", class: className = "" } = Astro.props;

const variantClasses = {
  light:
    "bg-white p-6 md:p-7 lg:p-8 border border-line transition-all duration-300 hover:border-ink hover:shadow-card-hover",
  dark:
    "bg-white/[0.04] p-6 md:p-7 lg:p-8 border border-white/15 transition-all duration-300 hover:border-white/40",
};
---

<div class:list={[variantClasses[variant], className]}>
  <slot />
</div>
