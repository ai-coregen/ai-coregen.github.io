---
import JaText from "./JaText.astro";

interface Props {
  number: string;
  title: string;
  description: string;
  isLast?: boolean;
}

const { number, title, description, isLast = false } = Astro.props;
---

<div class="flex gap-4 lg:gap-6">
  <!-- Line + Circle -->
  <div class="flex flex-col items-center">
    <div
      class="w-10 h-10 lg:w-12 lg:h-12 rounded-full bg-ink text-white flex items-center justify-center font-display font-bold text-base lg:text-lg shrink-0"
    >
      {number}
    </div>
    {
      !isLast && (
        <div class="w-px bg-line flex-1 min-h-[40px] mt-2" />
      )
    }
  </div>
  <!-- Content -->
  <div class:list={["pb-8 lg:pb-10", isLast && "pb-0"]}>
    <h4 class="text-ink font-bold text-lg lg:text-xl mb-1">
      {title}
    </h4>
    <JaText tag="p" text={description} class="text-ink text-[15px] sm:text-base" />
  </div>
</div>
