---
interface Props {
  eyebrow?: string;
  dark?: boolean;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  dark = false,
  align = "left",
  class: className = "",
} = Astro.props;

const isCenter = align === "center";
// 下線バー: 黒(50px)→薄グレー。中央寄せ時はダーク背景でテール色を反転
const barStyle = dark
  ? "background: linear-gradient(90deg, #ffffff 50px, rgba(255,255,255,0.25) 0);"
  : "background: linear-gradient(90deg, #121213 50px, var(--color-tail) 0);";
---

<div
  class:list={[
    "mb-12 lg:mb-16",
    isCenter ? "text-center" : "text-left",
    className,
  ]}
>
  {
    eyebrow && (
      <p
        class:list={[
          "font-display font-bold text-base sm:text-lg tracking-[0.14em] mb-4",
          dark ? "text-white/60" : "text-ink",
        ]}
      >
        {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      "text-[clamp(1.75rem,2.6vw+0.75rem,2.5rem)] leading-[1.35] font-bold",
      dark ? "text-white" : "text-ink",
    ]}
  >
    <slot />
  </h2>
  <div
    class:list={["h-1 mt-6", isCenter ? "mx-auto w-full max-w-[200px]" : "w-full"]}
    style={barStyle}
  >
  </div>
</div>
