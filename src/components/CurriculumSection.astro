---
import SectionHeading from "./ui/SectionHeading.astro";
import Button from "./ui/Button.astro";
import JaText from "./ui/JaText.astro";
import { curriculum } from "../data/content";

const toolIcons = [
  // ChatGPT
  "ChatGPT",
  // Gemini
  "Gemini",
  // Claude
  "Claude",
  // Copilot
  "Copilot",
];
---

<section class="bg-white py-16 lg:py-24" id="curriculum">
  <div class="max-w-[1100px] mx-auto px-6">
    <SectionHeading>
      <JaText tag="span" text={curriculum.heading} class="" />
    </SectionHeading>

    <!-- Tool table -->
    <div
      class="max-w-[800px] mx-auto rounded-xl shadow-card overflow-hidden mb-10"
      data-animate
    >
      {curriculum.tools.map((tool, i) => (
        <div
          class:list={[
            "flex items-center gap-4 lg:gap-6 p-5 lg:p-6",
            i % 2 === 0 ? "bg-white" : "bg-primary-50/50",
          ]}
        >
          <!-- Tool icon placeholder -->
          <div class="w-10 h-10 lg:w-12 lg:h-12 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
            <span class="text-primary-500 font-bold text-xs lg:text-sm">{toolIcons[i].slice(0, 2)}</span>
          </div>
          <!-- Tool info -->
          <div class="flex-1 min-w-0">
            <h4 class="text-neutral-900 font-bold text-base lg:text-lg">
              {tool.name}
            </h4>
            <JaText tag="p" text={tool.description} class="text-neutral-600 text-sm" />
          </div>
        </div>
      ))}
    </div>

    <!-- Direction -->
    <div class="max-w-[600px] mx-auto mb-10" data-animate data-delay="100">
      <ul class="space-y-3">
        {curriculum.direction.map((item) => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <JaText tag="p" text={item} class="text-neutral-700 text-[13px] sm:text-[0.95rem]" />
          </li>
        ))}
      </ul>
    </div>

    <!-- CTA -->
    <div class="text-center" data-animate data-delay="200">
      <Button variant="primary">
        {curriculum.cta}
      </Button>
    </div>
  </div>
</section>
