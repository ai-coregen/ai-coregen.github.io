---
import SectionHeading from "./ui/SectionHeading.astro";
import Button from "./ui/Button.astro";
import JaText from "./ui/JaText.astro";
import { curriculum } from "../data/content";
---

<section class="bg-white py-20 lg:py-32" id="curriculum">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={curriculum.eyebrow}>
      <JaText tag="span" text={curriculum.heading} class="" />
    </SectionHeading>

    <!-- Lead -->
    <div class="max-w-[860px] mb-3" data-animate>
      <JaText tag="p" text={curriculum.leadCopy} class="text-ink font-bold text-[15px] sm:text-lg lg:text-xl leading-relaxed" />
    </div>
    <div class="max-w-[860px] mb-12" data-animate data-delay="80">
      <JaText tag="p" text={curriculum.intro} class="text-ink text-[13px] sm:text-[0.95rem] leading-relaxed" />
    </div>

    <!-- (1) 基礎動画学習: 9 videos -->
    <div class="mb-14" data-animate>
      <JaText tag="h3" text={curriculum.videosTitle} class="text-ink font-bold text-base lg:text-lg mb-5" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-line border border-line">
        {curriculum.videos.map((video, i) => (
          <div class="flex items-start gap-3 bg-white p-4 lg:p-5">
            <span class="font-display text-neutral-300 font-black text-xl leading-none shrink-0 w-7">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div class="flex-1 min-w-0">
              <h4 class="text-ink font-bold text-sm lg:text-[0.95rem] mb-1">{video.name}</h4>
              <JaText tag="p" text={video.description} class="text-mute text-xs lg:text-[13px] leading-relaxed" />
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- (2) カスタマイズワークショップ -->
    <div class="mb-14" data-animate>
      <JaText tag="h3" text={curriculum.workshopTitle} class="text-ink font-bold text-base lg:text-lg mb-3" />
      <JaText tag="p" text={curriculum.workshopLead} class="text-ink text-[13px] sm:text-[0.95rem] leading-relaxed mb-5" />
      <ul class="space-y-3 max-w-[760px]">
        {curriculum.workshopPoints.map((point) => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-ink shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <JaText tag="p" text={point} class="text-ink text-[13px] sm:text-[0.95rem]" />
          </li>
        ))}
      </ul>
    </div>

    <!-- (3) 伴走支援 -->
    <div class="mb-12" data-animate>
      <JaText tag="h3" text={curriculum.mentoringTitle} class="text-ink font-bold text-base lg:text-lg mb-3" />
      <JaText tag="p" text={curriculum.mentoringDescription} class="text-ink text-[13px] sm:text-[0.95rem] leading-relaxed max-w-[760px]" />
    </div>

    <!-- Closing -->
    <div class="bg-ink text-white p-7 lg:p-9 text-center mb-12" data-animate>
      <JaText tag="p" text={curriculum.closing} class="font-bold text-[clamp(0.95rem,1.6vw+0.5rem,1.25rem)] tracking-[0.06em] leading-relaxed" />
    </div>

    <!-- CTA -->
    <div class="text-center" data-animate>
      <Button variant="primary">
        {curriculum.cta}
      </Button>
    </div>
  </div>
</section>
