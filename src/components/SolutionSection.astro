---
import SectionHeading from "./ui/SectionHeading.astro";
import JaText from "./ui/JaText.astro";
import { solution } from "../data/content";
---

<section class="bg-gradient-subtle py-20 lg:py-32" id="solution">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={solution.eyebrow}>
      <JaText tag="span" text={solution.heading} class="" />
    </SectionHeading>

    <!-- Philosophy statement -->
    <div class="max-w-[820px] mb-14" data-animate>
      {solution.body.map((line) => (
        <JaText tag="p" text={line} class="text-neutral-700 text-[14px] sm:text-base lg:text-lg leading-loose mb-3 last:mb-0" />
      ))}
    </div>

    <!-- Flow diagram: 業務効率化 → コスト削減 → 配置転換 → 売上最大化 -->
    <div class="max-w-[980px] mx-auto mb-12">
      <div class="flex flex-col lg:flex-row items-stretch gap-3 lg:gap-2">
        {solution.flowSteps.map((text, i) => (
          <>
            <div
              class:list={[
                "flex-1 border p-5 lg:p-6 text-center flex flex-col items-center justify-center",
                i === solution.flowSteps.length - 1
                  ? "bg-ink border-ink"
                  : "bg-white border-line",
              ]}
              data-animate
              data-delay={i * 150}
            >
              <div
                class:list={[
                  "w-9 h-9 rounded-full font-display font-bold flex items-center justify-center mb-3 text-sm",
                  i === solution.flowSteps.length - 1
                    ? "bg-white text-ink"
                    : "bg-ink text-white",
                ]}
              >
                {`0${i + 1}`}
              </div>
              <JaText
                tag="p"
                text={text}
                class:list={[
                  "font-bold text-[13px] sm:text-[0.95rem] lg:text-base",
                  i === solution.flowSteps.length - 1 ? "text-white" : "text-ink",
                ]}
              />
            </div>
            {i < solution.flowSteps.length - 1 && (
              <div class="flex items-center justify-center py-1 lg:py-0">
                <!-- Desktop: right arrow / Mobile: down arrow -->
                <svg class="hidden lg:block w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
                <svg class="lg:hidden w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
                </svg>
              </div>
            )}
          </>
        ))}
      </div>
    </div>

    <!-- Closing -->
    <div data-animate>
      <JaText tag="p" text={solution.closing} class="text-mute text-sm" />
    </div>
  </div>
</section>
