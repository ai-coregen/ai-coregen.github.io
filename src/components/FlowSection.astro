---
import SectionHeading from "./ui/SectionHeading.astro";
import StepNode from "./ui/StepNode.astro";
import JaText from "./ui/JaText.astro";
import { flow } from "../data/content";
---

<section class="bg-gradient-subtle py-20 lg:py-32" id="flow">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={flow.eyebrow}>
      <span class="lg:whitespace-nowrap lg:tracking-[0.02em]">{flow.heading}</span>
    </SectionHeading>

    <div class="max-w-[600px] mx-auto">
      {flow.steps.map((step, i) => (
        <div data-animate data-delay={i * 120}>
          <StepNode
            number={step.number}
            title={step.title}
            description={step.description}
            isLast={i === flow.steps.length - 1}
          />
        </div>
      ))}
    </div>

    <!-- 完全成果報酬の注記（強調） -->
    <div class="max-w-[600px] mx-auto mt-10" data-animate>
      <div class="bg-ink text-white p-6 lg:p-7 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
        <span class="font-display font-bold text-[11px] tracking-[0.16em] uppercase border border-white/30 rounded-full px-3.5 py-1 shrink-0 self-start sm:self-center">
          完全成果報酬
        </span>
        <JaText tag="p" text={flow.note} class="font-bold text-[14px] sm:text-base leading-relaxed" />
      </div>
    </div>
  </div>
</section>
