---
import SectionHeading from "./ui/SectionHeading.astro";
import JaText from "./ui/JaText.astro";
import { features } from "../data/content";

const icons = [
  `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" />
  </svg>`,
  `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
  </svg>`,
  `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>`,
];

const num = ["01", "02", "03"];
---

<section class="bg-surface py-20 lg:py-32" id="features">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={features.eyebrow}>
      <JaText tag="span" text={features.heading} class="" />
    </SectionHeading>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6 items-stretch">
      {features.items.map((item, i) => (
        <div data-animate data-delay={i * 120} class="h-full">
          <div
            class="group h-full bg-white p-7 lg:p-8 border border-line border-t-[3px] border-t-ink transition-shadow duration-300"
            style="filter: drop-shadow(0 6px 16px rgba(18,18,19,0.06));"
          >
            <div class="flex items-center justify-between mb-5">
              <div class="w-12 h-12 bg-ink flex items-center justify-center text-white">
                <Fragment set:html={icons[i]} />
              </div>
              <span class="font-display text-neutral-200 font-black text-3xl leading-none">
                {num[i]}
              </span>
            </div>
            <JaText tag="h3" text={item.title} class="text-ink font-bold text-lg lg:text-xl mb-3" />
            <JaText tag="p" text={item.description} class="text-ink text-[13px] sm:text-[0.95rem] leading-relaxed" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
