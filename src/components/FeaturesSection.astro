---
import SectionHeading from "./ui/SectionHeading.astro";
import JaText from "./ui/JaText.astro";
import { features } from "../data/content";

const num = ["01", "02", "03"];
---

<section class="bg-surface py-20 lg:py-32" id="features">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
    <SectionHeading eyebrow={features.eyebrow}>
      <JaText tag="span" text={features.heading} class="" />
    </SectionHeading>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6 items-stretch">
      {features.items.map((item, i) => (
        <div data-animate data-delay={i * 120} class="h-full">
          <div
            class="group h-full bg-white p-7 lg:p-8 border border-line border-t-[3px] border-t-ink transition-shadow duration-300 flex flex-col items-center"
            style="filter: drop-shadow(0 6px 16px rgba(18,18,19,0.06));"
          >
            <!-- 丸囲み数字（理念セクションと同じ書き方） -->
            <div class="w-10 h-10 rounded-full bg-ink text-white font-display font-bold flex items-center justify-center text-sm mb-5 shrink-0">
              {num[i]}
            </div>
            <!-- テキストは左揃えのまま、ブロックを中央に配置（幅を絞って中央寄せ） -->
            <div class="text-left max-w-[230px] mx-auto">
              <!-- 見出し・本文とも通常折り返し（語の途中でも改行し、右端を揃える） -->
              <h3 class="text-ink font-bold text-lg lg:text-xl mb-3">{item.title}</h3>
              <p class="text-ink text-[15px] sm:text-base leading-relaxed">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
