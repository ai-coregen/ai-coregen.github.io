---
import Layout from "../layouts/Layout.astro";
import { footer, downloadForm } from "../data/content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const home = `${base}/`;
const privacyHref = `${base}/privacy`;
const ready = !!downloadForm.gasUrl;
---

<Layout
  title="サービス詳細資料ダウンロード｜CoreGen"
  description="CoreGenのサービス詳細資料を無料でダウンロードいただけます。"
>
  <header class="border-b border-line">
    <div class="max-w-[800px] mx-auto px-6 h-20 flex items-center">
      <a href={home} class="flex items-center group min-h-[44px]">
        <span class="text-ink font-display font-black text-3xl tracking-[0.02em] group-hover:opacity-60 transition-opacity">
          CoreGen
        </span>
      </a>
    </div>
  </header>

  <main class="max-w-[640px] mx-auto px-6 py-16 lg:py-24">
    <p class="font-display font-bold text-base sm:text-lg tracking-[0.14em] text-ink mb-4">
      {downloadForm.eyebrow}
    </p>
    <h1 class="text-ink font-bold text-2xl lg:text-3xl mb-5 tracking-[0.04em] leading-snug">
      {downloadForm.heading}
    </h1>
    <p class="text-ink text-base leading-relaxed mb-10">
      {downloadForm.lead}
    </p>

    <!-- 資料の内容 -->
    <div class="bg-surface border border-line p-6 lg:p-7 mb-10">
      <p class="text-ink font-bold text-base mb-4">{downloadForm.materialsTitle}</p>
      <ul class="space-y-2.5">
        {downloadForm.materials.map((item) => (
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-ink shrink-0 mt-2.5"></span>
            <p class="text-ink text-[15px] leading-relaxed">{item}</p>
          </li>
        ))}
      </ul>
    </div>

    <!-- フォーム -->
    <form id="dl-form" data-gas-url={downloadForm.gasUrl} class="space-y-6" novalidate>
      <div>
        <label for="dl-company" class="block text-ink font-bold text-[15px] mb-2">
          {downloadForm.companyLabel}<span class="text-brand-orange ml-1">*</span>
        </label>
        <input
          id="dl-company"
          name="companyName"
          type="text"
          required
          autocomplete="organization"
          placeholder={downloadForm.companyPlaceholder}
          class="w-full border border-line bg-white px-4 py-3 text-ink text-base focus:outline-none focus:border-ink transition-colors"
        />
      </div>
      <div>
        <label for="dl-email" class="block text-ink font-bold text-[15px] mb-2">
          {downloadForm.emailLabel}<span class="text-brand-orange ml-1">*</span>
        </label>
        <input
          id="dl-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder={downloadForm.emailPlaceholder}
          class="w-full border border-line bg-white px-4 py-3 text-ink text-base focus:outline-none focus:border-ink transition-colors"
        />
      </div>

      <!-- honeypot（スパム対策・人間には非表示） -->
      <div class="absolute left-[-9999px]" aria-hidden="true">
        <label>このフィールドは空のままにしてください<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
      </div>

      <p id="dl-error" class="hidden text-brand-orange text-sm font-bold"></p>

      <button
        id="dl-submit"
        type="submit"
        disabled={!ready}
        class="group relative inline-flex w-full items-center justify-center bg-ink text-white font-display font-bold text-base tracking-[0.02em] rounded-full pl-8 pr-14 py-[18px] transition-all duration-300 hover:opacity-80 disabled:opacity-40 disabled:cursor-not-allowed"
      >
        <span id="dl-submit-label">{downloadForm.submit}</span>
        <svg class="absolute right-4 sm:right-5 top-1/2 -translate-y-1/2 w-7 h-7" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <circle cx="16" cy="16" r="16" fill="rgba(255,255,255,0.18)" />
          <path d="M13.5 10.5 L21 16 L13.5 21.5 Z" fill="#ffffff" />
        </svg>
      </button>

      <p class="text-mute text-[13px] leading-relaxed">
        ご入力いただいた個人情報は、<a href={privacyHref} class="underline hover:opacity-60">{footer.company[1].label}</a>に基づき大切に取り扱います。
      </p>
      {!ready && (
        <p class="text-brand-orange text-[13px] font-bold">{downloadForm.preparingNote}</p>
      )}
    </form>

    <!-- 送信完了 -->
    <div id="dl-success" class="hidden text-center py-10">
      <div class="w-14 h-14 rounded-full bg-ink flex items-center justify-center mx-auto mb-5">
        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h2 class="text-ink font-bold text-xl mb-3">{downloadForm.successTitle}</h2>
      <p class="text-ink text-[15px] leading-relaxed max-w-[440px] mx-auto">{downloadForm.successBody}</p>
      <a href={home} class="inline-flex items-center gap-2 text-ink text-sm font-bold hover:opacity-60 transition-opacity mt-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        トップページに戻る
      </a>
    </div>

    <div class="mt-12">
      <a href={home} class="inline-flex items-center gap-2 text-ink text-sm font-bold hover:opacity-60 transition-opacity">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        トップページに戻る
      </a>
    </div>
  </main>

  <footer class="border-t border-line">
    <div class="max-w-[640px] mx-auto px-6 py-6">
      <p class="text-neutral-400 text-[13px] text-center">{footer.copyright}</p>
    </div>
  </footer>
</Layout>

<script>
  const form = document.getElementById("dl-form") as HTMLFormElement | null;
  const successBox = document.getElementById("dl-success");
  const errorEl = document.getElementById("dl-error");
  const submitBtn = document.getElementById("dl-submit") as HTMLButtonElement | null;
  const submitLabel = document.getElementById("dl-submit-label");

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function showError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  if (form && submitBtn) {
    const gasUrl = form.dataset.gasUrl || "";
    const sendingText = "送信中…";
    const defaultLabel = submitLabel?.textContent || "資料を受け取る";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl?.classList.add("hidden");

      const data = new FormData(form);
      const companyName = String(data.get("companyName") || "").trim();
      const email = String(data.get("email") || "").trim();
      const honeypot = String(data.get("_gotcha") || "");

      if (honeypot) return; // bot
      if (!companyName) return showError("会社名をご入力ください。");
      if (!EMAIL_RE.test(email)) return showError("メールアドレスの形式をご確認ください。");
      if (!gasUrl) return showError("現在準備中です。しばらくお待ちください。");

      submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = sendingText;

      try {
        // GASウェブアプリはCORSヘッダを返さないため no-cors で送信（レスポンスは読まない）
        await fetch(gasUrl, {
          method: "POST",
          mode: "no-cors",
          body: JSON.stringify({ companyName, email }),
        });
        form.classList.add("hidden");
        successBox?.classList.remove("hidden");
        successBox?.scrollIntoView({ behavior: "smooth", block: "center" });
      } catch {
        // no-cors では基本ここに来ないが、保険として成功扱い（送信自体は実行される）
        form.classList.add("hidden");
        successBox?.classList.remove("hidden");
      } finally {
        submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = defaultLabel;
      }
    });
  }
</script>
