---
import Layout from "../layouts/Layout.astro";
import { footer } from "../data/content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const home = `${base}/`;

const rows = [
  { label: "販売事業者", value: "FRUOR" },
  { label: "運営統括責任者", value: footer.companyInfo.rep },
  { label: "所在地", value: footer.companyInfo.address },
  {
    label: "電話番号",
    value: "請求があった場合、遅滞なく開示いたします。",
  },
  {
    label: "お問い合わせ",
    value:
      "本サイトのお問い合わせフォーム、または公式X（@Hoshino_Sokichi）よりご連絡ください。",
  },
  {
    label: "販売価格",
    value:
      "サービス内容に応じて個別にお見積りし、ご契約前に提示いたします（最初の3〜5回は無料／以降は成果が出るまで完全成果報酬制）。",
  },
  {
    label: "商品代金以外の必要料金",
    value: "消費税、振込手数料（お客様負担）。",
  },
  {
    label: "提供時期",
    value: "ご契約後、別途定める日程にて順次提供いたします。",
  },
  { label: "お支払い方法", value: "銀行振込。" },
  {
    label: "お支払い時期",
    value: "サービス提供後、請求書に記載の期日までにお支払いください。",
  },
  {
    label: "返品・キャンセル",
    value:
      "役務（サービス）の性質上、提供開始後の返金はお受けできません。提供開始前のキャンセルについてはお問い合わせください。",
  },
];
---

<Layout
  title="特定商取引法に基づく表記｜FRUOR"
  description="FRUOR（AI実装研修）の特定商取引法に基づく表記です。"
>
  <header class="border-b border-line">
    <div class="max-w-[800px] mx-auto px-6 h-16 flex items-center">
      <a href={home} class="flex items-center gap-2.5 group min-h-[44px]">
        <div class="w-8 h-8 bg-ink flex items-center justify-center">
          <span class="text-white font-display font-black text-base leading-none">F</span>
        </div>
        <span class="text-ink font-display font-bold text-base tracking-[0.22em] group-hover:opacity-60 transition-opacity">
          FRUOR
        </span>
      </a>
    </div>
  </header>

  <main class="max-w-[800px] mx-auto px-6 py-16 lg:py-24">
    <h1 class="text-ink font-bold text-2xl lg:text-3xl mb-3 tracking-[0.04em]">
      特定商取引法に基づく表記
    </h1>
    <p class="text-neutral-500 text-sm mb-12">最終更新日：2026年6月6日</p>

    <dl class="border-t border-line">
      {rows.map((row) => (
        <div class="flex flex-col sm:flex-row gap-1 sm:gap-6 py-5 border-b border-line">
          <dt class="text-ink font-bold text-sm sm:w-48 shrink-0">{row.label}</dt>
          <dd class="text-neutral-700 text-sm leading-relaxed flex-1">{row.value}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-12">
      <a href={home} class="inline-flex items-center gap-2 text-ink text-sm font-bold hover:opacity-60 transition-opacity">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        トップページに戻る
      </a>
    </div>
  </main>

  <footer class="border-t border-line">
    <div class="max-w-[800px] mx-auto px-6 py-6">
      <p class="text-neutral-400 text-[13px] text-center">{footer.copyright}</p>
    </div>
  </footer>
</Layout>
