---
import "../styles/global.css";
import { tracking } from "../data/content";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
// GA4（合計流入のみ。個社特定はtoken側）。ga4Idが空ならタグを出さない
const GA_ID = tracking.ga4Id;

// base path を含めた favicon パス（Astro の base 設定に追従）
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// ?v= はキャッシュ無効化用（ファビコン更新時にバージョンを上げる）
const faviconHref = `${base}/favicon.svg?v=coregen-dots2`;
// OGP画像（絶対URL。SNSは相対パス不可）。?v= は更新時のキャッシュ無効化用
const ogImage = new URL(`${base}/ogp.png?v=1`, Astro.site).href;
// 現在ページの正規URL（canonical / og:url 用。クエリ・末尾は正規化）
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="CoreGen" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="alternate icon" href={faviconHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <!-- 和文フォールバック（Yu Gothic未搭載環境用） -->
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <!-- 欧文ディスプレイ（見出しラベル・ボタン用 Satoshi） -->
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@500,700,900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {GA_ID && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_ID}');`}></script>
      </Fragment>
    )}
  </head>
  <body>
    <slot />
    <script>
      // Scroll-reveal animation using IntersectionObserver.
      // Replaces AOS library which fails on mobile Safari due to
      // offsetTop calculation bugs with overflow-x:hidden.
      function initScrollReveal() {
        const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
        if (!targets.length) return;

        // Apply per-element transition-delay from data-delay attribute
        targets.forEach((el) => {
          const delay = el.dataset.delay;
          if (delay) {
            el.style.transitionDelay = `${delay}ms`;
          }
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            // Trigger when 10% of the element is visible,
            // or when it is within 40px of the viewport bottom
            threshold: 0.1,
            rootMargin: "0px 0px -40px 0px",
          }
        );

        targets.forEach((el) => observer.observe(el));
      }

      // Run after DOM is ready (module scripts are deferred by default)
      initScrollReveal();
    </script>
    <script>
      // ユニークリンク(?c=token)の訪問ビーコン。全ページで1回。token無ければ何もしない。
      import { getToken, trackVisit } from "../lib/track";
      import { tracking } from "../data/content";
      trackVisit(tracking.logUrl, getToken(), location.pathname);
    </script>
  </body>
</html>
